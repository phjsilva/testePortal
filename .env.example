# Exemplo de variáveis de ambiente para o PortalScrum
# Copie este arquivo para .env e preencha com suas credenciais reais
# IMPORTANTE: A credencial de banco exposta anteriormente deve ser trocada no painel do Neon.tech

DATABASE_URL=postgresql://usuario:senha@host:porta/banco?sslmode=require
PORT=3000

POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha
POSTGRES_DB=bdaula
POSTGRES_PORT=5432

JWT_SECRET=seu_jwt_secret_forte
DEFAULT_EXPIRES_IN_SECONDS=900000